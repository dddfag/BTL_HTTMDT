# VietQR Environment Variables Template

# Thêm những biến này vào file .env của backend

# ========== VietQR Payment Configuration ==========
# Mã ngân hàng (xem danh sách tại https://vietqr.io/)
VIET_QR_BANK_CODE=970436

# Số tài khoản nhân thanh toán
VIET_QR_ACCOUNT_NUMBER=0123456789

# Tên chủ tài khoản (để hiển thị trên QR)
VIET_QR_ACCOUNT_NAME=AUFFUR FURNITURE

# ========== Danh sách mã ngân hàng phổ biến ==========
# 970436 - MB (Ngân hàng Quân Đội)
# 970418 - ACB (Ngân hàng Á Châu)
# 970010 - BIDV (Ngân hàng Đầu tư và Phát triển)
# 970007 - Vietcombank
# 970405 - Techcombank
# 970015 - Vietinbank
# 970429 - Sacombank
# 970437 - TPBank
# 970441 - MSB
# Xem thêm tại: https://vietqr.io/
